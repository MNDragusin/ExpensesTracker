@page "/expenses"
@using ExpensesTracker.Server.Services
@using ExpensesTracker.Common.EntityModel.Sqlite

@inject IWalletController WalletController;
@rendermode InteractiveServer
@attribute [StreamRendering]

<PageTitle>Expenses</PageTitle>
<h3>Expenses</h3>

<AuthorizeView>
<Authorized>

<ImportData OnParseCallback="OnDataImported"/>
<div class="form-group">
    <a class="btn btn-info" href="AddNewExpense">
        <i class="oi oi-plus"></i> Add new
    </a>
</div>

@if (_expenses is null)
{
    <div class="align-content-center spinner-border">
    </div>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Date</th>
            <th>Wallet</th>
            <th>Category</th>
            <th>Label</th>
            <th>Amount</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var entry in _expenses)
        {
            <tr>
                <th>@entry.Date</th>
                <th>@_wallets.FirstOrDefault(w=>w.WalletId == entry.WalletId)!.Name</th>
                <th>@_categories.FirstOrDefault(c=>c.Id == entry.CategoryId)!.Name</th>
                <th>@_labels.FirstOrDefault(l=>l.Id == entry.LabelId)!.Name</th>
                <th>@entry.Amount</th>
                <th>
                    <a class="btn btn-info" href="editEntry/{@entry.EntryId}">
                        <i class="fluent--pen-20-filled"></i>
                    </a>
                    <a class="btn btn-danger" href="removeEntity/{@entry.EntryId}">
                        <i class="ooui--trash"></i>
                    </a>
                </th>
            </tr>
        }
        </tbody>
    </table>
}
    </Authorized>
    </AuthorizeView>

@code {
    private IEnumerable<WalletEntry> _expenses;
    private IEnumerable<Category> _categories;
    private IEnumerable<Wallet> _wallets;
    private IEnumerable<Label> _labels;

    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; }
    
    protected override async Task OnInitializedAsync()
    {
        var user = (await authenticationStateTask).User;

        _wallets = await WalletController.GetWallets(user.Identity.Name);
        _labels = await WalletController.GetLabels(user.Identity.Name);
        _categories = await WalletController.GetCategories(user.Identity.Name);

        List<WalletEntry> results = new();
        foreach (var wallet in _wallets)
        {
            var result = (await WalletController.GetAllExpenses(wallet.WalletId));
            results.AddRange(result);
        }
        
        _expenses = results.OrderBy(p => p.Date);
    }

    private void OnDataImported(IEnumerable<WalletEntry> entries)
    {
        _expenses = entries;
    }
}