@using ExpensesTracker.Pages
@using ExpensesTracker.Common.EntityModel.Sqlite
@inherits ExpensesBase
@page "/expenses"

<PageTitle>Expenses</PageTitle>
<h3>Expenses</h3>

<AuthorizeView>
    <Authorized>
        <div class="row">
            <div class="form-group col-5">
                <MudButton Href="AddNewExpense" Variant="Variant.Text" Color="Color.Primary">Add new</MudButton>
            </div>
        </div>
        <MudSpacer />
            @if(!ShowLoading)
            {
                <MudDataGrid T="WalletEntry" Items="@_expenses" SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="x => x.Date" />
                        <PropertyColumn Property="x => _wallets.FirstOrDefault(w => w.Id == x.WalletId)!.Name" Title="Wallet"/>
                        <PropertyColumn Property="x => _categories.FirstOrDefault(c => c.Id == x.CategoryId)!.Name" Title="Category"/>
                        <PropertyColumn Property="x => _labels.FirstOrDefault(l => l.Id == x.LabelId)!.Name" Title="Label"/>
                        <PropertyColumn Property="x => x.Amount" Filterable="false"/>
                        <TemplateColumn CellClass="d-flex justify-end" Filterable="false">
                            <CellTemplate Context="ItemContext">
                                <MudStack Row>
                                    <MudIconButton HRef="@($"EditEntry/{ItemContext.Item.EntryId}")" Icon="@Icons.Material.Filled.Edit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" />
                                    <MudIconButton ButtonType="ButtonType.Button" OnClick="@(()=>RemoveEntry(ItemContext.Item.EntryId))" Icon="@Icons.Material.Filled.Delete" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" />
                                </MudStack>        
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <PagerContent>
                        <MudDataGridPager T="WalletEntry" />
                    </PagerContent>
                </MudDataGrid>
            }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
